    bool "I2C support"
    default y

config SPI
    bool "SPI support"
    default n

config SERIAL
    bool "Serial driver"
    default y

config GPIO
    bool "GPIO support"
    default y

endmenu

menu "File systems"

config EXT4
    bool "Ext4 filesystem"
    default y

config SQUASHFS
    bool "SquashFS support"
    default y

config OVERLAY_FS
    bool "Overlay filesystem"
    default n

