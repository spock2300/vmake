menu "General Setup"

config LOCALVERSION
    string "Local version - append to kernel release"
    default "-vmake"

config ARCH
    string "Architecture"
    default "x86_64"

endmenu

menu "Device Drivers"

config NET
    bool "Networking support"
    default y

